# Safety: never accidentally commit business files if they get dropped in.
# Patterns are scoped to file extensions used by business docs so they don't
# block legitimate public blog post HTML files containing similar words.
*.xlsx
*.pptx
*.docx
*Investor_Memo*.pdf
*Investor_Memo*.html
*Deal_Underwriting*.pdf
*Deal_Underwriting*.html
UW_*.html
UW_*.pdf
*Deal_Pipeline*.html
*Deal_Pipeline*.pdf
*Deal_Tracker*.html
*Deal_Tracker*.pdf
*Waterfall*.xlsx
*Waterfall*.pdf
*OM*.pdf
/LLC*
/Archive*
/Deals*
/Boynton*
/Lake_Worth*

# Local working/backup files — never ship
portal.PRECLEAN-backup.html
portal.bak-r8
CLAUDE_CODE_PROMPT.md
push_update.bat
*.bak
*.bak-*

# Refresh-task local artifacts (snapshots of the real log/state + debug fallback)
tools/real_refresh_log.txt
tools/real_refresh_state.txt
tools/refresh_task_debug.log
tools/steer_state_once.bat
tools/__pycache__/

# Digest: local state/log + credentials/recipients (PII + secrets — never commit)
tools/digest_state.json
tools/digest.log
tools/digest_smtp.json
tools/digest_recipients.txt

# Field Intel: dated memos are PAID subscriber content — only the template ships
tools/field-intel/2*.html

# Inbound leads: real contact details, never publish
tools/inbox/

# FDOR mutex — runtime state, machine-local
tools/.fdor.lock
